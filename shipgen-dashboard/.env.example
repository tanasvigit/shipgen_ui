# Copy to `.env` and adjust. Vite exposes only variables prefixed with VITE_.

# Required for production: HTTPS origin of your API (include path if the API is mounted under /api)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Legacy alias — used only if VITE_API_BASE_URL is unset
# VITE_API_BASE=http://localhost:4000/api

# Set to "true" only for frontend-only demos (in-memory mock data; auth still hits real /int/v1/auth unless mocked)
# VITE_USE_MOCK_API=false

# Set to "true" only for local UI work — skips login (dangerous if deployed)
# VITE_DISABLE_AUTH=false

# Optional: auth dev fallback — see src/config/auth.config.ts
# VITE_DEV_AUTH=false

# Optional: enables Google Places autocomplete + Google geocoding in Order location input
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
