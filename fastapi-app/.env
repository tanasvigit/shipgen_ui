APP_NAME="ShipGen API (FastAPI)"
ENV="development"
DEBUG=true

# Postgres database settings
# Update these values if your local Postgres credentials are different.
DB_CONNECTION="postgresql+psycopg2"
DB_HOST="localhost"
DB_PORT=5432
DB_DATABASE="shipgen"
DB_USERNAME="postgres"
DB_PASSWORD="postgres"

# JWT
JWT_SECRET_KEY="CHANGE_ME_SECRET"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4201","http://localhost:4200","http://127.0.0.1:4201","http://127.0.0.1:4200","http://10.46.55.177:5173","http://192.168.0.171:5173","http://192.168.1.129:5173"]

PORT=8000
